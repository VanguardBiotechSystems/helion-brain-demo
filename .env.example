# ============================================================
# Helion — Cerebro conversacional para robot humanoide
# Copia este archivo a .env.local (desarrollo) o configura
# estas variables en tu plataforma cloud (Vercel/Render/Railway).
# NUNCA commitees un archivo con claves reales.
# ============================================================

# ── OpenAI (obligatorio) ────────────────────────────────────
# Clave secreta de OpenAI. Solo vive en el servidor; el navegador
# recibe únicamente un token efímero por sesión.
OPENAI_API_KEY=

# ── OpenAI (opcional, con valores por defecto sensatos) ─────
# Modelo realtime speech-to-speech. Por defecto: gpt-realtime-2.1
# Alternativas: gpt-realtime-2.1-mini (más barato), gpt-realtime, gpt-realtime-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Voz OpenAI del agente (solo en modo openai_realtime).
# Orden recomendado para masculina/juvenil: cedar, ash, echo, verse.
# IMPORTANTE: ninguna voz de OpenAI es española nativa; el acento se moldea
# por instrucciones. Para voz española real usa VOICE_ENGINE=elevenlabs.
OPENAI_REALTIME_VOICE=cedar

# Modelo de transcripción del audio del usuario (para subtítulos).
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Idioma esperado del usuario (ISO-639-1). Usa "auto" para autodetección.
OPENAI_TRANSCRIPTION_LANGUAGE=es

# Detección de turnos de conversación: semantic_vad | server_vad
OPENAI_TURN_DETECTION=semantic_vad

# Modelo de texto para el modo fallback sin micrófono.
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Base URL de la API de OpenAI (solo cambiar si usas un proxy).
# OPENAI_BASE_URL=https://api.openai.com

# ── Motor de voz ────────────────────────────────────────────
# openai_realtime: speech-to-speech por WebRTC (latencia mínima). Las voces
#   son las de OpenAI: buenas, pero ninguna suena 100 % española nativa.
# elevenlabs: los oídos y el cerebro siguen siendo OpenAI Realtime, pero la
#   voz la sintetiza ElevenLabs (voz española nativa real, algo más de
#   latencia). Requiere ELEVENLABS_API_KEY y ELEVENLABS_VOICE_ID.
# Modo demo actual: elevenlabs (voz española nativa en streaming).
VOICE_ENGINE=elevenlabs

# ── ElevenLabs (solo si VOICE_ENGINE=elevenlabs, o para probar voz) ─
# Cómo conseguir las credenciales:
#   1) Crea cuenta en https://elevenlabs.io
#   2) Perfil → API Keys → crea una clave y pégala abajo
#   3) Voice Library → filtra idioma "Spanish", acento "Castilian/Peninsular",
#      voz masculina joven → añádela a tu cuenta ("Add to My Voices") →
#      My Voices → ⋯ → "Copy voice ID"
#   4) Reinicia la app y pulsa «Probar voz española» en el panel de diagnóstico
# OJO: usar voces de la Voice Library por API requiere plan de pago (Starter+).
# En el plan gratuito solo funcionan por API las voces por defecto de tu
# cuenta (velas en la app o con GET /v1/voices).
# No uses clones de voces de personas reales sin consentimiento explícito.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Latencia de voz (modo elevenlabs) ───────────────────────
# http_stream (recomendado para Vercel/serverless): streaming HTTP chunked.
# websocket_stream se acepta y se resuelve a http_stream (ver DEMO_HANDOFF §8).
# http_full = pipeline clásico estable (espera la respuesta completa).
ELEVENLABS_TTS_MODE=http_stream
# Reservado para el modo WebSocket de fase 2 (sin efecto en http_stream):
# ELEVENLABS_AUTO_MODE=true
# Velocidad de habla (0.7–1.2). 1.08 = ritmo conversacional algo más ágil.
ELEVENLABS_SPEED=1.08
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.75
# style > 0 añade latencia según ElevenLabs; súbelo solo si prefieres expresividad.
ELEVENLABS_STYLE=0
ELEVENLABS_USE_SPEAKER_BOOST=false
# Chunking: el primer fragmento sale con la primera unidad natural.
ELEVENLABS_FIRST_CHUNK_MIN_CHARS=12
ELEVENLABS_CHUNK_MIN_CHARS=35
ELEVENLABS_MAX_CHUNK_WAIT_MS=80
ELEVENLABS_AUDIO_START_BUFFER_MS=50

# Cerebro en modo rápido: esfuerzo de razonamiento y brevedad.
HELION_REASONING_EFFORT=low
HELION_LATENCY_MODE=fast
HELION_MAX_NORMAL_SENTENCES=1
# La memoria nunca bloquea el camino crítico más de esto (ms).
MEMORY_MAX_BLOCKING_MS=200

# ── Escucha y gate de audio (ver docs/AUDIO_GATE.md) ────────
# Perfil de escucha: fija defaults de VAD, reducción de ruido y gate local.
# demo_balanced (defecto): voz conversacional normal, sin perder inicios.
# laptop_demo: variante estricta para entornos ruidosos.
# near_field | far_field | robot_room: otros escenarios.
AUDIO_PROFILE=demo_balanced

# Overrides individuales del VAD de OpenAI (opcionales; pisan el perfil):
# OPENAI_TURN_DETECTION=server_vad        # semantic_vad | server_vad
# OPENAI_VAD_THRESHOLD=0.6                # 0..1 (solo server_vad; más alto = menos sensible)
# OPENAI_VAD_SILENCE_MS=700               # silencio para cerrar turno (server_vad)
# OPENAI_VAD_PREFIX_PADDING_MS=300        # audio previo incluido (server_vad)
# OPENAI_VAD_EAGERNESS=low                # low|medium|high|auto (solo semantic_vad)
# OPENAI_NOISE_REDUCTION=near_field       # near_field | far_field | off

# Gate local (rechazo de tecleo/golpes ANTES de enviar audio a OpenAI).
# Los valores por defecto vienen del perfil; descomenta para forzar:
LOCAL_AUDIO_GATE_ENABLED=true
LOCAL_AUDIO_CALIBRATION_MS=2000
# LOCAL_AUDIO_MIN_SPEECH_MS=220
# LOCAL_AUDIO_SPIKE_REJECTION_MS=160
LOCAL_AUDIO_THRESHOLD_MULTIPLIER=2.0
# AGC del navegador (off recomendado: no amplificar ruido de fondo)
LOCAL_AUDIO_AGC=false

# ── Memoria persistente (ver docs/MEMORY_ARCHITECTURE.md) ───
MEMORY_ENABLED=true
# postgres (PRODUCCIÓN): Neon/Supabase/RDS; requiere DATABASE_URL.
# local: archivo JSON (.data/) — solo desarrollo (en Vercel es efímero).
MEMORY_PROVIDER=postgres
DATABASE_URL=
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EXTRACTION_MODEL=gpt-4.1-mini
MEMORY_RETRIEVAL_TOP_K=8
MEMORY_MIN_IMPORTANCE=0.55
MEMORY_AUTO_SAVE=true
MEMORY_REQUIRE_CONFIRMATION_FOR_SENSITIVE=true
# Días tras los que los recuerdos episódicos poco importantes se archivan
# (vacío = sin caducidad)
MEMORY_RETENTION_DAYS=
MEMORY_DEBUG=false

# ── Acceso a la demo (obligatorio) ──────────────────────────
# Passcode que se pide al abrir la web. Compártelo solo con
# quien deba probar la demo.
APP_ACCESS_PASSWORD=

# (Recomendado) Secreto aleatorio (>= 32 caracteres) para firmar la
# cookie de sesión. Genera uno con: openssl rand -hex 32
# Si se omite, se deriva de APP_ACCESS_PASSWORD (menos robusto).
SESSION_SECRET=

# ── Identidad del producto ──────────────────────────────────
# Nombre del agente (se usa en su personalidad y en la UI).
AGENT_NAME=Helion

# Nombre visible de la aplicación.
NEXT_PUBLIC_APP_NAME=Helion

# ── Identidad: perfiles de acceso ───────────────────────────
# Cada passcode identifica a una persona (el perfil viaja FIRMADO en la
# cookie). Recuerdos privados de un perfil son invisibles para el resto.
OWNER_PASSCODE=
SERGIO_PASSCODE=
INVESTOR_PASSCODE=
# Estructura a medida (opcional; passcodes vía passcodeEnv, nunca inline):
# ACCESS_PROFILES_JSON=[{"id":"juanma","displayName":"Juanma","role":"owner","passcodeEnv":"OWNER_PASSCODE"},{"id":"sergio","role":"robot_creator","passcodeEnv":"SERGIO_PASSCODE"}]
# Scope por defecto de recuerdos nuevos sin pista explícita:
MEMORY_DEFAULT_SCOPE=project_demo
# Autoconocimiento seguro (system_self) en las instrucciones:
SELF_KNOWLEDGE_ENABLED=true
