# ============================================================
# Helion — Cerebro conversacional para robot humanoide
# Copia este archivo a .env.local (desarrollo) o configura
# estas variables en tu plataforma cloud (Vercel/Render/Railway).
# NUNCA commitees un archivo con claves reales.
# ============================================================

# ── OpenAI (obligatorio) ────────────────────────────────────
# Clave secreta de OpenAI. Solo vive en el servidor; el navegador
# recibe únicamente un token efímero por sesión.
OPENAI_API_KEY=sk-coloca-aqui-tu-clave

# ── OpenAI (opcional, con valores por defecto sensatos) ─────
# Modelo realtime speech-to-speech. Por defecto: gpt-realtime-2.1
# Alternativas: gpt-realtime-2.1-mini (más barato), gpt-realtime, gpt-realtime-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Voz del agente. Disponibles: marin, cedar (recomendadas), alloy, ash,
# ballad, coral, echo, sage, shimmer, verse
OPENAI_REALTIME_VOICE=marin

# Modelo de transcripción del audio del usuario (para subtítulos).
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Idioma esperado del usuario (ISO-639-1). Usa "auto" para autodetección.
OPENAI_TRANSCRIPTION_LANGUAGE=es

# Detección de turnos de conversación: semantic_vad | server_vad
OPENAI_TURN_DETECTION=semantic_vad

# Modelo de texto para el modo fallback sin micrófono.
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Base URL de la API de OpenAI (solo cambiar si usas un proxy).
# OPENAI_BASE_URL=https://api.openai.com

# ── Acceso a la demo (obligatorio) ──────────────────────────
# Passcode que se pide al abrir la web. Compártelo solo con
# quien deba probar la demo.
APP_ACCESS_PASSWORD=cambia-este-passcode

# (Recomendado) Secreto aleatorio (>= 32 caracteres) para firmar la
# cookie de sesión. Genera uno con: openssl rand -hex 32
# Si se omite, se deriva de APP_ACCESS_PASSWORD (menos robusto).
SESSION_SECRET=

# ── Identidad del producto ──────────────────────────────────
# Nombre del agente (se usa en su personalidad y en la UI).
AGENT_NAME=Atlas

# Nombre visible de la aplicación.
NEXT_PUBLIC_APP_NAME=Helion
